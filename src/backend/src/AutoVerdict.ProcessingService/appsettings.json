{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Crawler": {
    "DefaultTimeoutSeconds": 60,
    "MaxAttempts": 3,
    "Sources": {
      "otomoto": {
        "AllowedDomains": [ "otomoto.pl", "www.otomoto.pl" ],
        "BlockedPaths": [ "/authentication", "/account", "/myaccount", "/login", "/oauth", "/api", "/ajax", "/contact" ],
        "MaxConcurrency": 1,
        "MinDelaySeconds": 10,
        "MaxDelaySeconds": 30,
        "MaxRequestsPerMinute": 3,
        "CaptchaIsRetryable": false
      }
    }
  }
}
