# Common
ASPNETCORE_ENVIRONMENT=Development
NODE_ENV=development

# Frontend
FRONTEND_PUBLIC_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:5000
NEXT_PUBLIC_API_URL=http://localhost:5000

# Backend
DATABASE_URL=Host=postgres;Port=5432;Database=autoverdict;Username=autoverdict;Password=autoverdict
NATS_URL=nats://nats:4222
ASPNETCORE_URLS=http://+:8080

# PostgreSQL
POSTGRES_DB=autoverdict
POSTGRES_USER=autoverdict
POSTGRES_PASSWORD=autoverdict

# Object storage
S3_ENDPOINT=http://seaweedfs:8333
S3_ACCESS_KEY=dev-access-key
S3_SECRET_KEY=dev-secret-key
S3_BUCKET=auto-verdict-local
S3_PUBLIC_PORT=8333

# AI provider
CLAUDE_API_KEY=
CLAUDE_MODEL=

# Playwright parser
# Defaults to headed in ASPNETCORE_ENVIRONMENT=Development and headless otherwise.
PLAYWRIGHT_HEADLESS=
PLAYWRIGHT_DEVTOOLS=false
PLAYWRIGHT_SLOW_MO_MS=0
PLAYWRIGHT_DEBUG_PAUSE_MS=0
PLAYWRIGHT_STORAGE_STATE_PATH=
PLAYWRIGHT_SAVE_STORAGE_STATE=false

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Authentication
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_SECRET=
